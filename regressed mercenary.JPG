/* Whole Page Styling */
body {
	margin: 0;
	font-family: "Arial", sans-serif;
	background-color: #e9e9e9;
	color: #222222;
}

/* Header Styling */
header {
	padding: 20px;
}

/* Navigation At The Top */
nav {
	text-align: center;
	font-weight: bold;
	font-size: 1.5em;
}
nav a {
	text-decoration: none;
	color: #f4a261;
	padding: 1em;
}
nav a: hover {
	color: #cc62f;
}

.trending {
	border-width: 2px;
	border-style: sold;
	border-color: black;

	margin: 20px;
	padding: 20px;
	text-align: center;
}

.leftcolumn {
	float: left;
	width: 60%;
}

.rightcolumn {
	float: right;
	width: 30%;
}
.box {
	border-width: 2px;
	border-style: sold;
	border-color: black;

	padding: 20px;
	margin: 20px;
	text-align: center;
footer {
	clear: both;

	border-width: 2px;
	border-style: sold;
	border-color: black;

	text-align:center;
	padding: 20px;
	margin:20px;
}








